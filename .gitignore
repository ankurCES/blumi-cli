/target
**/*.rs.bk
*.pdb

# Stray Xcode/SwiftPM build output (e.g. from iOS tooling run at the repo root).
# blugo's own Flutter artifacts are ignored by blugo/.gitignore.
/build/

# blumi runtime data (never commit)
/.blumi/
blumi.db
blumi.db-*

# Frontend (blumi-web). dist/ is intentionally committed so rust-embed bakes the
# built UI into the binary — `cargo build` then works without running `npm`.
crates/blumi-web/frontend/node_modules/
crates/blumi-web/frontend/.vite/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
